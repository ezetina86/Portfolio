---
const locale = Astro.currentLocale;
---
<section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-base-bg to-gray-800 -z-10"></div>

  <div class="relative z-10 p-8 w-full max-w-4xl mx-auto">
    <div class="flex justify-center mb-1">
      <img src="/img/EZ-logo.png" alt="Enrique Zetina Logo" width="640" height="640" class="h-[340px] sm:h-[460px] md:h-[560px] w-auto" />
    </div>
    <h1 class="text-5xl md:text-7xl font-bold font-heading text-white leading-tight -mt-6 md:-mt-10">
      Enrique Zetina
    </h1>
    <p class="mt-3 text-2xl md:text-4xl font-bold font-heading bg-clip-text text-transparent bg-gradient-to-r from-primary to-secondary">
      {locale === 'es' ? 'Arquitecto Cloud Senior · Ingeniero 11x Certificado' : 'Senior Cloud Architect · 11x Certified Engineer'}
    </p>
    <p class="mt-4 text-lg md:text-xl text-gray-300 max-w-3xl mx-auto">
      {locale === 'es'
        ? 'Diseñando ecosistemas multi-nube de nivel empresarial en GCP, AWS y Azure para empresas Fortune 500 e instituciones financieras reguladas.'
        : 'Designing enterprise-grade, multi-cloud ecosystems across GCP, AWS, and Azure for Fortune 500 companies and regulated financial institutions.'}
    </p>
    <div class="mt-8 flex justify-center space-x-4">
      <a href="#projects" class="bg-primary text-white font-bold py-3 px-8 rounded-full hover:bg-opacity-90 transition-[background-color,opacity] duration-300 text-lg">
        {locale === 'es' ? 'Ver Proyectos' : 'View Projects'}
      </a>
      <a href="/downloads/Enrique_Zetina.pdf" class="bg-secondary text-white font-bold py-3 px-8 rounded-full hover:bg-opacity-90 transition-[background-color,opacity] duration-300 text-lg" target="_blank" rel="noopener noreferrer">
        {locale === 'es' ? 'Descargar CV' : 'Download Resume'}
      </a>
    </div>

    <!-- Terminal Window -->
    <div class="terminal-window mt-12 max-w-2xl mx-auto text-left animate-on-scroll" style="--stagger-index: 1;">
      <div class="terminal-header">
        <span class="terminal-dot red" aria-hidden="true"></span>
        <span class="terminal-dot yellow" aria-hidden="true"></span>
        <span class="terminal-dot green" aria-hidden="true"></span>
        <span class="terminal-title">~/portfolio — zsh</span>
      </div>
      <div
        class="terminal-body"
        id="terminal-output"
        role="img"
        aria-label={locale === 'es' ? 'Animación de terminal mostrando habilidades y experiencia' : 'Terminal animation showing skills and experience'}
      ></div>
    </div>
  </div>
</section>
