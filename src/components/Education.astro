---
const locale = Astro.currentLocale;
let education;
if (locale === 'es') {
  education = (await import('../data/education-es.js')).education;
} else {
  education = (await import('../data/education.js')).education;
}
---

<section id="education" class="py-10 sm:py-16">
  <div class="container mx-auto px-8">
    <h2 class="text-4xl font-bold font-heading text-center animate-on-scroll">{locale === 'es' ? 'Educación' : 'Education'}</h2>
    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8 stagger-children">
      {education.map((edu, index) => (
        <div class="bg-base-bg p-6 rounded-lg shadow-lg border border-gray-700/50 animate-on-scroll" style={`--stagger-index: ${index};`}>
          <div class="flex items-center mb-4">
            
            <div>
              <h3 class="text-xl font-bold font-heading text-primary">{edu.degree}</h3>
              <h4 class="text-lg font-semibold text-secondary">{edu.institution}</h4>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <p class="text-gray-400">{edu.period}</p>
            {edu.url && (
              <a
                href={edu.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-gray-500 hover:text-primary transition-colors"
              >
                {locale === 'es' ? 'Ver constancia →' : 'View certificate →'}
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>