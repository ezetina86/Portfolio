---
const locale = Astro.currentLocale;
let certifications;
if (locale === 'es') {
  certifications = (await import('../data/certifications-es.js')).certifications;
} else {
  certifications = (await import('../data/certifications.js')).certifications;
}

const levelOrder = { Professional: 0, Specialty: 1, Associate: 2, Foundational: 3 };

const providerMeta = {
  GCP:        { label: 'Google Cloud Platform', color: '#3B82F6' },
  AWS:        { label: 'Amazon Web Services',   color: '#F97316' },
  Azure:      { label: 'Microsoft Azure',       color: '#38BDF8' },
  HashiCorp:  { label: 'HashiCorp',             color: '#8B5CF6' },
  Astronomer: { label: 'Astronomer',            color: '#0D9488' },
};

const levelMeta = {
  Professional: {
    labelEn: 'Professional', labelEs: 'Profesional',
    classes: 'bg-primary/10 text-primary border border-primary/30',
    topColor: '#0D9488',
  },
  Specialty: {
    labelEn: 'Specialty', labelEs: 'Especialidad',
    classes: 'bg-accent/10 text-accent border border-accent/30',
    topColor: '#F59E0B',
  },
  Associate: {
    labelEn: 'Associate', labelEs: 'Asociado',
    classes: 'bg-secondary/10 text-secondary border border-secondary/30',
    topColor: '#3B82F6',
  },
  Foundational: {
    labelEn: 'Foundational', labelEs: 'Fundamentos',
    classes: 'bg-gray-700/50 text-gray-400 border border-gray-600/30',
    topColor: null,
  },
};

const providerOrder = ['GCP', 'AWS', 'Azure', 'HashiCorp', 'Astronomer'];

// Group by provider
const grouped: Record<string, typeof certifications> = {};
for (const cert of certifications) {
  if (!grouped[cert.provider]) grouped[cert.provider] = [];
  grouped[cert.provider].push(cert);
}

// Sort each group: highest level first
for (const p of providerOrder) {
  if (grouped[p]) {
    grouped[p].sort((a, b) => (levelOrder[a.level] ?? 99) - (levelOrder[b.level] ?? 99));
  }
}

const activeProviders = providerOrder.filter(p => grouped[p]);

// Providers with 3+ certs get their own section; the rest share one combined row
const SOLO_THRESHOLD = 3;
const mainProviders = activeProviders.filter(p => grouped[p].length >= SOLO_THRESHOLD);
const otherCerts = activeProviders
  .filter(p => grouped[p].length < SOLO_THRESHOLD)
  .flatMap(p => grouped[p]);
---

<section id="certifications" class="py-10 sm:py-16 bg-gray-900/50 animate-on-scroll">
  <div class="container mx-auto px-8">

    <h2 class="text-4xl font-bold font-heading text-center animate-on-scroll">
      {locale === 'es' ? 'Certificaciones' : 'Certifications'}
    </h2>

    <!-- Stats bar -->
    <div class="mt-8 flex flex-wrap justify-center items-center gap-3 animate-on-scroll">
      <div class="flex items-center gap-2 bg-base-bg border border-gray-700/50 rounded-full px-5 py-2">
        <span class="text-xl font-bold text-primary">{certifications.length}</span>
        <span class="text-gray-400 text-sm">
          {locale === 'es' ? 'Certificaciones Activas' : 'Active Certifications'}
        </span>
      </div>
      {activeProviders.map(provider => (
        <div class="flex items-center gap-1.5 bg-base-bg border border-gray-700/50 rounded-full px-4 py-1.5">
          <span class="text-sm font-bold" style={`color: ${providerMeta[provider].color}`}>
            {grouped[provider].length}
          </span>
          <span class="text-gray-500 text-xs">{provider}</span>
        </div>
      ))}
    </div>

    <!-- Legend -->
    <div class="mt-5 flex flex-wrap justify-center gap-3 animate-on-scroll">
      {Object.entries(levelMeta).map(([level, meta]) => (
        <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${meta.classes}`}>
          {locale === 'es' ? meta.labelEs : meta.labelEn}
        </span>
      ))}
    </div>

    <!-- Provider groups -->
    <div class="mt-10 space-y-10">

      <!-- Main providers (≥3 certs): own labeled section each -->
      {mainProviders.map(provider => (
        <div class="animate-on-scroll">
          <div class="flex items-center gap-3 mb-5">
            <span
              class="text-sm font-bold tracking-wide uppercase"
              style={`color: ${providerMeta[provider].color}`}
            >
              {providerMeta[provider].label}
            </span>
            <span class="text-gray-600 text-xs">({grouped[provider].length})</span>
            <div class="flex-1 h-px bg-gray-700/40"></div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3">
            {grouped[provider].map(cert => {
              const meta = levelMeta[cert.level] ?? levelMeta.Foundational;
              const levelLabel = locale === 'es' ? meta.labelEs : meta.labelEn;
              return (
                <a
                  href={cert.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${cert.title} — ${locale === 'es' ? 'Verificar credencial' : 'Verify credential'}`}
                  class="group bg-base-bg border border-gray-700/50 rounded-xl p-4 flex flex-col items-center text-center transition-all duration-300 hover:-translate-y-1 hover:border-gray-500 hover:shadow-lg hover:shadow-black/30"
                  style={meta.topColor ? `border-top: 2px solid ${meta.topColor}` : ''}
                >
                  <img src={cert.image} alt={cert.title} width="72" height="72" class="w-16 h-16 object-contain mb-3" loading="lazy" />
                  <span class={`text-xs font-semibold px-2 py-0.5 rounded-full mb-2 ${meta.classes}`}>{levelLabel}</span>
                  <p class="text-xs text-gray-300 leading-snug group-hover:text-white transition-colors line-clamp-3 flex-1">{cert.title}</p>
                  <span class="mt-3 text-xs text-gray-600 group-hover:text-primary transition-colors">
                    {locale === 'es' ? 'Verificar →' : 'Verify →'}
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      ))}

      <!-- Combined row for providers with <3 certs -->
      {otherCerts.length > 0 && (
        <div class="animate-on-scroll">
          <div class="flex items-center gap-3 mb-5">
            <span class="text-sm font-bold tracking-wide uppercase text-gray-400">
              {locale === 'es' ? 'Certificaciones Adicionales' : 'Additional Certifications'}
            </span>
            <span class="text-gray-600 text-xs">({otherCerts.length})</span>
            <div class="flex-1 h-px bg-gray-700/40"></div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3">
            {otherCerts.map(cert => {
              const meta = levelMeta[cert.level] ?? levelMeta.Foundational;
              const levelLabel = locale === 'es' ? meta.labelEs : meta.labelEn;
              const provider = providerMeta[cert.provider];
              return (
                <a
                  href={cert.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${cert.title} — ${locale === 'es' ? 'Verificar credencial' : 'Verify credential'}`}
                  class="group bg-base-bg border border-gray-700/50 rounded-xl p-4 flex flex-col items-center text-center transition-all duration-300 hover:-translate-y-1 hover:border-gray-500 hover:shadow-lg hover:shadow-black/30"
                  style={meta.topColor ? `border-top: 2px solid ${meta.topColor}` : ''}
                >
                  <img src={cert.image} alt={cert.title} width="72" height="72" class="w-16 h-16 object-contain mb-3" loading="lazy" />
                  <!-- Provider chip -->
                  <span class="text-xs font-bold px-2 py-0.5 rounded mb-1.5" style={`color: ${provider?.color ?? '#9CA3AF'}; background: ${provider?.color ?? '#9CA3AF'}18`}>
                    {cert.provider}
                  </span>
                  <span class={`text-xs font-semibold px-2 py-0.5 rounded-full mb-2 ${meta.classes}`}>{levelLabel}</span>
                  <p class="text-xs text-gray-300 leading-snug group-hover:text-white transition-colors line-clamp-3 flex-1">{cert.title}</p>
                  <span class="mt-3 text-xs text-gray-600 group-hover:text-primary transition-colors">
                    {locale === 'es' ? 'Verificar →' : 'Verify →'}
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      )}

    </div>

  </div>
</section>
